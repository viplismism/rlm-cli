# Pick one provider and set its API key:

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Google (Gemini)
# GEMINI_API_KEY=AIza...

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...

# Model override (optional — auto-selects based on provider)
# RLM_MODEL=claude-sonnet-4-6
